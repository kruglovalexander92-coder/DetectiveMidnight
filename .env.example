# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Choose your LLM provider: 'gemini' or 'litellm' (default: litellm)
# - gemini: Uses Google Gemini API (requires @google/genai package)
# - litellm: Uses OpenAI-compatible API via LiteLLM proxy (no additional dependencies)
LLM_PROVIDER=litellm

# =============================================================================
# LITELLM PROVIDER SETTINGS (used when LLM_PROVIDER=litellm)
# =============================================================================
# OPENAI_API_KEY: Required API key for the LLM proxy.
# Note: Do NOT wrap API keys in quotes
OPENAI_API_KEY=sk-your-api-key

# OPENAI_BASE_URL: Base URL of an OpenAI-compatible endpoint (e.g. LiteLLM proxy).
# Note: Do NOT wrap URLs in quotes
OPENAI_BASE_URL=https://hcbifrost.herocraft.com/litellm/v1

# OPENAI_MODEL: Primary model name routed by the proxy.
OPENAI_MODEL="MiniMax-M3"

# OPENAI_FALLBACK_MODEL: Secondary model used if the primary fails.
OPENAI_FALLBACK_MODEL="mimo-v2.5"

# =============================================================================
# GEMINI PROVIDER SETTINGS (used when LLM_PROVIDER=gemini)
# =============================================================================
# GEMINI_API_KEY: Required for Gemini AI API calls.
# Note: Do NOT wrap API keys in quotes
# Get your key from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key

# GEMINI_MODEL: Primary Gemini model (default: gemini-3.5-flash).
# GEMINI_MODEL="gemini-3.5-flash"

# GEMINI_FALLBACK_MODEL: Fallback Gemini model (default: gemini-2.5-flash).
# GEMINI_FALLBACK_MODEL="gemini-2.5-flash"

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# =============================================================================
# NEURO NPCs GAME TUNING
# =============================================================================
# TURN_CAP: Maximum number of dialogue turns per round.
TURN_CAP=15

# REL_Q1: Relationship threshold to unlock the first case question (default: 40).
REL_Q1=40

# REL_Q2: Relationship threshold to unlock the second case question (default: 65).
REL_Q2=65

# REL_Q3: Relationship threshold to unlock the third case question (default: 90).
REL_Q3=90

# REL_Q4: Relationship threshold to unlock the fourth case question (default: 95).
REL_Q4=95

# REL_Q_DEGRADATION: Base relationship penalty when asking a case question (multiplied by NPC aggressiveness, default: 10).
REL_Q_DEGRADATION=10

# REL_Q_DEGRADATION_WRONG_PIC: Relationship penalty when photo composite doesn't match (multiplied by NPC temper, default: 20).
REL_Q_DEGRADATION_WRONG_PIC=20
